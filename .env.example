BOT_TOKEN=your_telegram_bot_token_here
LOG_LEVEL=INFO

# Comma-separated Telegram user IDs allowed to use the bot.
# Empty = bot accepts NOBODY (fail-closed).
# Get your user ID by messaging @userinfobot on Telegram.
ALLOWLIST_USER_IDS=

# Per-user rate limit: max requests per window (seconds).
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# Audit DB path (inside container). 90-day retention.
AUDIT_DB_PATH=/data/audit.db
AUDIT_RETENTION_DAYS=90

# Optional: set to enable Sentry error tracking. Leave unset to disable.
SENTRY_DSN=
