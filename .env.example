BOT_TOKEN=your_telegram_bot_token_here
LOG_LEVEL=INFO

# Per-user rate limit: max requests per window (seconds).
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# Abuse detection: auto-deny if user exceeds this many requests per day (UTC).
DAILY_ABUSE_THRESHOLD=20

# Audit DB path (inside container). 90-day retention.
# For local dev (no docker), use: AUDIT_DB_PATH=./data/audit.db
AUDIT_DB_PATH=/data/audit.db
AUDIT_RETENTION_DAYS=90

# Plate search allowlist: comma-separated Telegram user IDs allowed to use /placa.
# Empty = nobody can use plate search (fail-closed).
PLATE_ALLOWED_USER_IDS=

# Admin user IDs for /stats access: comma-separated Telegram user IDs.
# Empty = nobody can see stats (fail-closed).
ADMIN_USER_IDS=

# RNP vehicle plate search credentials.
# Option A — single account (backward compatible):
# RNP_EMAIL=your_rnp_email@example.com
# RNP_PASSWORD=your_rnp_password
#
# Option B — credential pool (round-robin, each account has its own rate limit):
# RNP_ACCOUNTS=user1@example.com:pass1,user2@example.com:pass2
#
# Shared settings:
# RNP_TIMEOUT=30 (optional, default 30 seconds)
# RNP_BASE_URL=https://www.rnpdigital.com (optional, default production)

# Optional: set to enable Sentry error tracking. Leave unset to disable.
SENTRY_DSN=
